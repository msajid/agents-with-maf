{
    "name": "Python Development",
    "image": "mcr.microsoft.com/devcontainers/python:3.14",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.pylint",
                "ms-python.black-formatter"
            ]
        }
    },
    "postCreateCommand": "pip install -r requirements.txt"
}